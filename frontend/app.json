{
  "expo": {
    "name": "Barcode Reader",
    "slug": "barcode-reader",
    "version": "1.0.0",
    "sdkVersion": "54.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "newArchEnabled": false,
    "splash": {
      "resizeMode": "contain",
      "backgroundColor": "#0A0A0A"
    },
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSCameraUsageDescription": "This app uses the camera to scan barcodes and QR codes."
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#0A0A0A"
      },
      "permissions": [
        "android.permission.CAMERA"
      ],
      "package": "com.prince1229.barcodereader",
      "targetSdkVersion": 34
    },
    "web": {
      "bundler": "metro",
      "description": "Premium Barcode & QR Scanner for Inventory Management",
      "backgroundColor": "#0A0A0A",
      "themeColor": "#00E5FF",
      "display": "standalone",
      "startUrl": "/"
    },
    "plugins": [
      [
        "expo-camera",
        {
          "cameraPermission": "Allow Barcode Reader to access your camera to scan barcodes and QR codes."
        }
      ]
    ]
  }
}
